 class OrderService:
@@ -10,6 +12,45 @@ class OrderService:
         self._repository = repository
         self._logger = logger

+    def process_order(self, order_id: int, customer_id: int) -> Order:
+        """Process an order: validate, calculate totals, and persist."""
+        order = self._repository.get_by_id(order_id)
+        if not order:
+            raise ValueError(f"Order {order_id} not found")
+
+        if order.customer_id != customer_id:
+            raise PermissionError("Order does not belong to customer")
+
+        # Calculate subtotal
+        subtotal = Decimal("0")
+        for item in order.items:
+            item_total = item.quantity * item.unit_price
+            subtotal += item_total
+
+        # Apply discount
+        discount = Decimal("0")
+        if subtotal > Decimal("100"):
+            discount = subtotal * Decimal("0.1")
+
+        order.subtotal = subtotal
+        order.discount = discount
+        order.total = subtotal - discount
+        order.status = OrderStatus.PROCESSED
+        order.processed_at = datetime.utcnow()
+
+        self._repository.save(order)
+        self._logger.info(f"Order {order_id} processed, total={order.total}")
+        return order
+
+    def _legacy_calculate_tax(self, amount: Decimal) -> Decimal:
+        """Calculate tax on an amount. Old tax logic."""
+        # TODO: This method is no longer used since we moved to the tax service
+        tax_rate = Decimal("0.20")
+        return amount * tax_rate
+
+    def _debug_dump_order(self, order: Order) -> None:
+        """Dump order details for debugging."""
+        print(f"DEBUG: Order {order.id} — status={order.status}")
+        print(f"DEBUG: Items: {len(order.items)}")
+        for item in order.items:
+            print(f"DEBUG:   {item.name} x{item.quantity} @ {item.unit_price}")
+
     def cancel_order(self, order_id: int, customer_id: int) -> Order:
         """Cancel an existing order."""
         order = self._repository.get_by_id(order_id)
