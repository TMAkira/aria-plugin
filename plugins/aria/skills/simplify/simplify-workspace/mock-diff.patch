@@ -10,6 +11,35 @@ class InvoiceService:
         self._repository = repository
         self._logger = logger

+    def generate_invoice(self, order) -> Invoice:
+        """Generate an invoice from a processed order."""
+        if order.status != "PROCESSED":
+            raise ValueError("Can only invoice processed orders")
+
+        # Calculate subtotal
+        subtotal = Decimal("0")
+        for item in order.items:
+            item_total = item.quantity * item.unit_price
+            subtotal += item_total
+
+        # Apply discount
+        discount = Decimal("0")
+        if subtotal > Decimal("100"):
+            discount = subtotal * Decimal("0.1")
+
+        total = subtotal - discount
+
+        invoice = Invoice(
+            order_id=order.id,
+            customer_id=order.customer_id,
+            subtotal=subtotal,
+            discount=discount,
+            total=total,
+            status=InvoiceStatus.DRAFT,
+            created_at=datetime.utcnow(),
+        )
+
+        self._repository.save(invoice)
+        self._logger.info(f"Invoice generated for order {order.id}")
+        return invoice
+
     def void_invoice(self, invoice_id: int) -> Invoice:
         """Void an existing invoice."""
         invoice = self._repository.get_by_id(invoice_id)
diff --git a/src/utils/formatting.py b/src/utils/formatting.py
new file mode 100644
index 0000000..a1b2c3d
--- /dev/null
+++ b/src/utils/formatting.py
@@ -0,0 +1,18 @@
+from decimal import Decimal
+
+
+def format_currency(amount: Decimal, currency: str = "EUR") -> str:
+    """Format a decimal amount as a currency string."""
+    symbols = {"EUR": "\u20ac", "USD": "$", "GBP": "\u00a3"}
+    symbol = symbols.get(currency, currency)
+    return f"{symbol}{amount:.2f}"
+
+
+def format_percentage(value: Decimal) -> str:
+    """Format a decimal as a percentage string."""
+    return f"{value * 100:.1f}%"
+
+
+def truncate_string(text: str, max_length: int = 50) -> str:
+    """Truncate a string to a maximum length with ellipsis."""
+    return text if len(text) <= max_length else text[:max_length - 3] + "..."
